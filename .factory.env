# Factory 3.0 — heybeaux.dev Configuration
# Astro + Tailwind site, deployed on Vercel via git push

# Git
FACTORY_BASE_BRANCH=main
FACTORY_REMOTE=origin

# Environment overrides
HUSKY=0
CI=true

# Timeouts (seconds) — Astro builds are fast
FACTORY_WORKER_TIMEOUT=300
FACTORY_GATE_TIMEOUT=60

# Concurrency — site is simple, 2 workers max
FACTORY_MAX_WORKERS=2

# Build gates — Astro build is the main gate (no test suite yet)
FACTORY_GATE_LINT=echo "no linter configured"
FACTORY_GATE_TYPECHECK=npx astro check 2>/dev/null || true
FACTORY_GATE_TEST=npm run build

# Worker model — Sonnet for component work, simple enough
FACTORY_WORKER_MODEL=sonnet

# No Linear integration for heybeaux (tasks come from specs, not tickets)
# LINEAR_API_KEY=
# LINEAR_TEAM_ID=

# Engram (for metrics)
ENGRAM_API_KEY=eng_d5ed9b39cf101706702e5f16bd326ab0eb5d7151ebb1f0f6
ENGRAM_USER_ID=beaux
ENGRAM_AGENT_ID=rook

# Debugger — 1 round max, site is simple
FACTORY_MAX_DEBUG_ROUNDS=1
FACTORY_SKIP_DEBUGGER=false
FACTORY_BASELINE_GATES=true
