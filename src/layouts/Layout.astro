---
import '../styles/global.css'

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "heybeaux.dev — Beaux Walton", 
  description = "The central domain for Beaux Walton's products, labs, agent infrastructure, and client work." 
} = Astro.props;
---

<!doctype html>
<html lang="en" class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
    
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-61TZH46X7P"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-61TZH46X7P');
    </script>
  </head>
  <body class="min-h-screen bg-[var(--color-bg)] text-[var(--color-text)]">
    <header class="border-b border-[var(--color-border)] bg-[rgba(247,246,242,0.86)] backdrop-blur">
      <nav class="max-w-6xl mx-auto px-5 md:px-8 py-4 flex flex-wrap items-center justify-between gap-4">
        <a href="/" class="font-mono text-sm text-[var(--color-text)] hover:text-[var(--color-accent)]">
          heybeaux.dev
        </a>
        <div class="flex flex-wrap items-center gap-4 text-sm font-mono text-[var(--color-muted)]">
          <a href="/#projects">Projects</a>
          <a href="/#about">About</a>
          <a href="/blog">Writing</a>
          <a href="/#contact">Contact</a>
        </div>
      </nav>
    </header>
    
    <main class="max-w-6xl mx-auto px-5 md:px-8 py-10 md:py-16">
      <slot />
    </main>
    
    <footer class="border-t border-[var(--color-border)] mt-20 bg-[rgba(255,255,255,0.45)]">
      <div class="max-w-6xl mx-auto px-5 md:px-8 py-8">
        <p class="text-sm text-[var(--color-muted)] font-mono">
          Made in Powell River, BC · central domain for products, labs, and client work · {new Date().getFullYear()}
        </p>
      </div>
    </footer>
  </body>
</html>
