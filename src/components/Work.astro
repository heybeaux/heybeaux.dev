const groups = ["Products", "Agent Stack", "Client Work"] as const;

const statusLabel = {
  active: "Active",
  "in-progress": "In progress",
  client: "Client",
  archive: "Archive",
  private: "Private"
};
---

<section id="projects" class="mb-16 md:mb-20">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-8">
    <div>
      <h2 class="text-sm font-mono text-[var(--color-accent)] mb-3 uppercase tracking-wider">
        Project Directory
      </h2>
      <p class="text-3xl md:text-4xl font-semibold max-w-3xl leading-tight">
        One domain, multiple product worlds.
      </p>
    </div>
    <p class="max-w-sm text-[var(--color-muted)]">
      The root site stays neutral. Each subdomain gets permission to use the design language that fits the thing it represents.
    </p>
  </div>

  <div class="space-y-10">
    {groups.map((group) => (
      <div>
        <div class="flex items-center gap-3 mb-4">
          <h3 class="font-mono text-xs uppercase tracking-wider text-[var(--color-muted)]">
            {group}
          </h3>
          <div class="h-px flex-1 bg-[var(--color-border)]"></div>
        </div>
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {projects.filter((project) => project.category === group).map((project) => (
            <article class="card p-5 md:p-6 group h-full flex flex-col" style={`--project-accent: ${project.accent}; --project-tint: ${project.tint};`}>
              <div class="flex items-start justify-between gap-4 mb-5">
                <div>
                  <p class="font-mono text-xs text-[var(--project-accent)] mb-2">
                    {project.eyebrow}
                  </p>
                  <h4 class="text-2xl font-semibold leading-tight">
                    {project.name}
                  </h4>
                </div>
                {project.status && (
                  <span class="tag shrink-0">{statusLabel[project.status]}</span>
                )}
              </div>

              <p class="text-sm font-mono text-[var(--color-muted)] mb-3">
                {project.role}
              </p>
              <p class="text-[var(--color-muted)] mb-5 flex-1">
                {project.description}
              </p>

              {project.tech && (
                <div class="flex flex-wrap gap-2 mb-5">
                  {project.tech.map((t) => (
                    <span class="text-xs font-mono text-[var(--color-muted)] bg-[var(--color-bg)] px-2 py-1 rounded border border-[var(--color-border)]">
                      {t}
                    </span>
                  ))}
                </div>
              )}

              {project.link && (
                <a href={project.link} target="_blank" rel="noopener noreferrer" class="font-mono text-sm text-[var(--project-accent)]">
                  Visit {project.eyebrow} →
                </a>
              )}
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<section class="mb-16 md:mb-20">
  <div class="grid gap-4 md:grid-cols-3">
    {[
      ["Root", "heybeaux.dev stays the index: who I am, what exists, and where each thing lives."],
      ["Subdomains", "Project sites can use their own palette, layout, voice, and conversion goals."],
      ["Ecosystems", "Related projects still cluster together, but standalone products no longer have to cosplay as Ginnung."]
    ].map(([label, body]) => (
      <div class="border-t-2 border-[var(--color-accent)] pt-4">
        <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-muted)] mb-2">{label}</p>
        <p class="text-lg leading-relaxed">{body}</p>
      </div>
    ))}
  </div>
</section>

<div class="section-divider"></div>
